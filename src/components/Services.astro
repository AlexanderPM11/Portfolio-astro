---
import { GetWpServices } from "../services/wpServices";
import { getIconComponent } from "../utils/iconMapper";
import SectionHeading from "./common/SectionHeading.astro";

const services = await GetWpServices();
---

<section id="services" class="py-20 px-8 bg-gray-900 border-t border-white/5 relative overflow-hidden">
  <!-- Elementos decorativos de fondo -->
  <div class="absolute top-10 left-10 w-32 h-32 bg-orange-500/5 rounded-full blur-xl animate-pulse"></div>
  <div class="absolute bottom-10 right-10 w-40 h-40 bg-purple-500/5 rounded-full blur-xl animate-pulse"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <SectionHeading
      label="Servicios Profesionales"
      title="Expertiz"
      highlight="Técnica"
      description="Consultoría y desarrollo a medida con un enfoque en la excelencia técnica y visual."
    />

    <!-- Tabbed Switcher Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_2.5fr] gap-12 relative mt-20 min-h-[500px]">
      
      <!-- Selectores de Servicios (Navegación Lateral) -->
      <nav 
        class="sticky top-24 z-30 flex lg:flex-col overflow-x-auto lg:overflow-x-visible pb-6 lg:pb-0 scrollbar-hide space-x-3 lg:space-x-0 lg:space-y-4"
        role="tablist"
      >
        {services.map((service, index) => (
          <button 
            type="button" 
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
            class={`service-tab-btn flex-none lg:w-full text-left relative transition-all duration-300 py-3 lg:py-5 px-6 lg:px-10 group ${index === 0 ? 'active' : ''}`}
            data-service-id={service.id}
          >
            <!-- Línea Indicadora Vertical (Inactiva: Sutil / Activa: Naranja) -->
            <div 
              class={`absolute left-0 top-0 bottom-0 w-[2px] transition-all duration-300 ${index === 0 ? 'bg-orange-500 scale-y-100' : 'bg-white/10 group-hover:bg-white/50 scale-y-50 group-hover:scale-y-100 group-hover:w-[1px]'}`}
            ></div>

            <!-- Contenido del Selector -->
            <div class="flex items-center gap-6">
              <span class={`font-light text-[10px] tracking-widest transition-all duration-300 ${index === 0 ? 'text-orange-500 opacity-100' : 'text-white/20 group-hover:text-white/60 group-hover:opacity-100'}`}>
                {(index + 1).toString().padStart(2, '0')}
              </span>
              <span class={`text-[11px] font-bold uppercase tracking-[0.3em] whitespace-nowrap lg:whitespace-normal transition-all duration-300 ${index === 0 ? 'text-orange-500' : 'text-white/40 group-hover:text-white'}`}>
                {service.title}
              </span>
            </div>
          </button>
        ))}
      </nav>

      <!-- Lado Derecho: Contenido Dinámico -->
      <div class="relative">
        {services.map((service, index) => {
          const Icon = getIconComponent(service.iconName);
          return (
            <div 
              class={`service-content-panel transition-all duration-700 transform ${index === 0 ? 'opacity-100 translate-y-0 relative z-10' : 'opacity-0 translate-y-12 hidden absolute inset-0'}`}
              data-service-id={service.id}
            >
              <!-- Cabecera del Servicio -->
              <header class="mb-10 flex items-center justify-between border-b border-white/5 pb-8">
                <div class="flex items-center gap-6">
                  <div class="w-14 h-14 rounded-2xl bg-linear-to-br from-orange-500 to-orange-600 flex items-center justify-center text-white shadow-2xl shadow-orange-500/20">
                    <Icon class="w-7 h-7" />
                  </div>
                  <div>
                    <span class="text-[9px] uppercase tracking-[0.4em] font-bold text-orange-500 block mb-1">
                       {service.label}
                    </span>
                    <h3 class="text-2xl md:text-4xl font-black text-white leading-tight">
                      {service.title}
                    </h3>
                  </div>
                </div>
                <span class="text-6xl font-black text-white/5 select-none hidden md:block">
                  {(index + 1).toString().padStart(2, '0')}
                </span>
              </header>

              <!-- Detalles del Servicio -->
              <div class="space-y-12">
                <p class="text-gray-300 text-lg md:text-xl leading-relaxed max-w-2xl font-light">
                  {service.description}
                </p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-end">
                  <div class="space-y-6">
                    <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/20 flex items-center gap-4">
                      <span class="w-10 h-px bg-white/10"></span>
                      Características
                    </h4>
                    <div class="grid grid-cols-1 gap-5">
                      {service.features.map((feature) => (
                        <div class="flex items-center gap-4 group/feature transition-all duration-300">
                          <div class="w-1 h-1 rounded-full bg-orange-500/30 group-hover/feature:bg-orange-500 shadow-[0_0_10px_rgba(249,115,22,0.3)]"></div>
                          <span class="text-[13px] font-medium text-white/60 group-hover/feature:text-white transition-colors">
                            {feature}
                          </span>
                        </div>
                      ))}
                    </div>
                  </div>

                  <div class="flex justify-end p-2">
                    <a
                      href="#contact"
                      class="group/cta relative inline-flex items-center gap-4 text-[11px] font-black uppercase tracking-[0.2em] text-white overflow-hidden py-4 px-10 rounded-2xl border border-white/10 hover:border-orange-500/30 transition-all duration-500 hover:shadow-2xl hover:shadow-orange-500/10"
                      onclick="scrollToSection(event, '#contact')"
                    >
                      <span class="relative z-10">Saber más</span>
                      <svg class="w-4 h-4 relative z-10 group-hover/cta:translate-x-2 transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                      </svg>
                      <div class="absolute inset-0 bg-orange-500 translate-y-full group-hover/cta:translate-y-0 transition-transform duration-500"></div>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Call to Action final -->
    <div class="text-center mt-20 pt-10 border-t border-white/5">
      <div class="bg-gray-800/50 backdrop-blur-md border border-white/5 rounded-3xl p-10 relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-64 h-64 bg-orange-500/5 rounded-full -translate-y-1/2 translate-x-1/2 blur-2xl group-hover:scale-110 transition-transform duration-700"></div>
        
        <div class="relative z-10">
          <h3 class="text-2xl font-bold text-white mb-4">
            ¿Listo para llevar tu proyecto al siguiente nivel?
          </h3>
          <p class="text-gray-400 mb-10 max-w-xl mx-auto text-sm leading-relaxed">
            Combinamos técnica, diseño y estrategia para crear soluciones digitales que marquen la diferencia. ¿Hablamos?
          </p>
          <div class="flex flex-col sm:flex-row gap-5 justify-center">
            <a
              href="#contact"
              class="bg-linear-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white px-10 py-4 rounded-2xl text-[12px] font-black uppercase tracking-widest transition-all duration-300 hover:shadow-2xl hover:shadow-orange-500/30 hover:-translate-y-1"
              onclick="scrollToSection(event, '#contact')"
            >
              Iniciar Proyecto
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function scrollToSection(e: Event, targetId: string) {
    e.preventDefault();
    const target = document.querySelector(targetId);
    if (target) {
      const headerHeight = 80;
      const targetPosition = target.getBoundingClientRect().top + window.pageYOffset;
      const offsetPosition = targetPosition - headerHeight;
      window.scrollTo({
        top: offsetPosition,
        behavior: 'smooth'
      });
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    // 1. Animaciones de Entrada (AOS)
    const observerOptions = { threshold: 0.1, rootMargin: '0px 0px -50px 0px' };
    const entryObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const target = entry.target as HTMLElement;
          target.style.opacity = '1';
          target.style.transform = 'translateY(0)';
          entryObserver.unobserve(target);
        }
      });
    }, observerOptions);

    document.querySelectorAll<HTMLElement>('[data-aos]:not(.service-content-panel)').forEach((el) => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(30px)';
      el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      entryObserver.observe(el);
    });

    // 2. Lógica del Conmutador de Servicios (Tabs)
    const tabBtns = document.querySelectorAll('.service-tab-btn');
    const contentPanels = document.querySelectorAll('.service-content-panel');

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        if (btn.classList.contains('active')) return;
        const targetId = btn.getAttribute('data-service-id');

        // A. Actualizar estado de los botones
        tabBtns.forEach(b => {
          const bIndicator = b.querySelector('div:first-child');
          const bNum = b.querySelector('span:nth-child(1)');
          const bTitle = b.querySelector('span:nth-child(2)');
          const isTarget = b === btn;
          
          b.setAttribute('aria-selected', isTarget ? 'true' : 'false');
          
          if (isTarget) {
            b.classList.add('active');
            // Indicador
            if (bIndicator) {
              bIndicator.classList.add('bg-orange-500', 'scale-y-100');
              bIndicator.classList.remove('bg-white/10', 'scale-y-50', 'w-[1px]');
            }
            // Numero
            if (bNum) {
              bNum.classList.add('text-orange-500', 'opacity-100');
              bNum.classList.remove('text-white/20');
            }
            // Titulo
            if (bTitle) {
              bTitle.classList.add('text-orange-500');
              bTitle.classList.remove('text-white/40');
            }
          } else {
            b.classList.remove('active');
            // Indicador
            if (bIndicator) {
              bIndicator.classList.remove('bg-orange-500', 'scale-y-100');
              bIndicator.classList.add('bg-white/10', 'scale-y-50');
            }
            // Numero
            if (bNum) {
              bNum.classList.remove('text-orange-500', 'opacity-100');
              bNum.classList.add('text-white/20');
            }
            // Titulo
            if (bTitle) {
              bTitle.classList.remove('text-orange-500');
              bTitle.classList.add('text-white/40');
            }
          }
        });

        // B. Cambiar paneles de contenido
        contentPanels.forEach(panel => {
          const htmlPanel = panel as HTMLElement;
          const isTarget = htmlPanel.getAttribute('data-service-id') === targetId;
          if (isTarget) {
            htmlPanel.classList.remove('hidden', 'absolute', 'inset-0');
            htmlPanel.classList.add('relative', 'z-10');
            void htmlPanel.offsetWidth;
            htmlPanel.classList.remove('opacity-0', 'translate-y-12');
            htmlPanel.classList.add('opacity-100', 'translate-y-0');
          } else {
            htmlPanel.classList.add('opacity-0', 'translate-y-12');
            htmlPanel.classList.remove('opacity-100', 'translate-y-0', 'relative', 'z-10');
            setTimeout(() => {
              if (htmlPanel.getAttribute('data-service-id') !== targetId) {
                htmlPanel.classList.add('hidden', 'absolute', 'inset-0');
              }
            }, 600);
          }
        });
      });
    });
  });
</script>