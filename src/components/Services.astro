---
import { GetWpServices } from "../services/wpServices";
import { getIconComponent } from "../utils/iconMapper";
import SectionHeading from "./common/SectionHeading.astro";

const services = await GetWpServices();
---

<section id="services" class="py-20 px-4 bg-linear-to-b from-gray-900 to-gray-800 relative overflow-hidden">
  <!-- Elementos decorativos de fondo -->
  <div class="absolute top-10 left-10 w-32 h-32 bg-orange-500/5 rounded-full blur-xl"></div>
  <div class="absolute bottom-10 right-10 w-40 h-40 bg-purple-500/5 rounded-full blur-xl"></div>
  <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-blue-500/3 rounded-full blur-2xl"></div>

  <div class="max-w-5xl mx-auto relative z-10 px-4">
    <SectionHeading
      label="Servicios Profesionales"
      title="Expertiz"
      highlight="Técnica"
      description="Soluciones digitales diseñadas con precisión y un enfoque en el rendimiento."
    />

    <!-- Lista minimalista de servicios -->
    <div class="flex flex-col border-t border-white/5">
      
      {services.map((service, index) => {
        const Icon = getIconComponent(service.iconName);
        return (
          <div 
            class="group py-12 flex flex-col md:flex-row gap-8 items-start md:items-center border-b border-white/5 last:border-0 hover:bg-white/5 transition-all duration-300 px-4 lg:px-8 relative"
            data-aos="fade-up"
            data-aos-delay={(index * 100).toString()}
          >
            <!-- Ícono minimalista -->
            <div class="shrink-0 relative">
              <div class="w-14 h-14 rounded-xl bg-orange-500/10 flex items-center justify-center text-orange-500 group-hover:bg-orange-500 group-hover:text-white transition-all duration-500 shadow-sm border border-orange-500/20">
                <Icon class="w-7 h-7" />
              </div>
            </div>

            <!-- Contenido principal -->
            <div class="grow min-w-0">
              <div class="flex flex-col mb-4">
                <span class="text-[10px] uppercase tracking-[0.2em] font-bold text-orange-500/70 mb-1">
                  {service.label}
                </span>
                <h3 class="text-xl md:text-2xl font-bold text-white group-hover:text-orange-400 transition-colors duration-300">
                  {service.title}
                </h3>
              </div>
              
              <p class="text-gray-400 text-sm md:text-base leading-relaxed max-w-2xl mb-5 group-hover:text-gray-300 transition-colors duration-300">
                {service.description}
              </p>
              
              <!-- Características compactas -->
              <div class="flex flex-wrap gap-2">
                {service.features.map((feature) => (
                  <span class="text-[10px] text-gray-500 bg-white/5 px-2 py-0.5 rounded border border-white/5 group-hover:border-orange-500/20 transition-all duration-300">
                    {feature}
                  </span>
                ))}
              </div>
            </div>

            <!-- CTA Integrado -->
            <div class="shrink-0 w-full md:w-auto mt-6 md:mt-0 pt-6 md:pt-0 border-t md:border-t-0 border-white/5">
              <a
                href="#contact"
                class="inline-flex items-center gap-2 text-sm font-medium text-gray-500 hover:text-orange-500 transition-all duration-300 group/link"
                onclick="scrollToSection(event, '#contact')"
              >
                <span>Saber más</span>
                <svg class="w-4 h-4 group-hover/link:translate-x-1 transition-transform duration-300 opacity-70 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Call to Action final mejorado -->
    <div class="text-center mt-16 pt-8 border-t border-white/10">
      <div class="bg-linear-to-r from-orange-500/10 to-purple-500/10 border border-white/10 rounded-2xl p-8 backdrop-blur-sm relative overflow-hidden">
        <!-- Elementos decorativos del CTA -->
        <div class="absolute top-0 right-0 w-32 h-32 bg-orange-500/5 rounded-full -translate-y-16 translate-x-16"></div>
        <div class="absolute bottom-0 left-0 w-40 h-40 bg-purple-500/5 rounded-full translate-y-16 -translate-x-16"></div>
        
        <div class="relative z-10">
          <h3 class="text-2xl font-bold text-white mb-4">
            ¿Listo para comenzar tu proyecto?
          </h3>
          <p class="text-gray-300 mb-6 max-w-2xl mx-auto text-lg">
            Trabajemos juntos para hacer realidad tus ideas. Contáctame y hablemos sobre cómo puedo ayudarte a alcanzar tus objetivos.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href="#contact"
              class="bg-linear-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white px-8 py-4 rounded-xl font-semibold transition-all duration-300 hover:shadow-2xl hover:shadow-orange-500/25 hover:-translate-y-1 inline-flex items-center gap-3"
              onclick="scrollToSection(event, '#contact')"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
              Iniciar conversación
            </a>
            <a
              href="#portfolio"
              class="border border-white/20 hover:border-orange-500/50 text-white px-8 py-4 rounded-xl font-semibold transition-all duration-300 hover:bg-white/5 inline-flex items-center gap-3"
              onclick="scrollToSection(event, '#portfolio')"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9v-9m0-9v9"/>
              </svg>
              Ver proyectos
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Animaciones personalizadas */
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }
  
  .group:hover .floating-icon {
    animation: float 2s ease-in-out infinite;
  }

  /* Mejoras de scroll suave */
  html {
    scroll-behavior: smooth;
  }
</style>

<script>
  function scrollToSection(e:Event, targetId:string) {
    e.preventDefault();
    const target = document.querySelector(targetId)!;
    if (target) {
      const headerHeight = 80;
      const targetPosition = target.getBoundingClientRect().top + window.pageYOffset;
      const offsetPosition = targetPosition - headerHeight;

      window.scrollTo({
        top: offsetPosition,
        behavior: 'smooth'
      });
    }
  }

  // Efecto de aparición progresiva
  document.addEventListener('DOMContentLoaded', () => {
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

   const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          // Hacer type assertion para que TS reconozca style
          const target = entry.target as HTMLElement;
          target.style.opacity = '1';
          target.style.transform = 'translateY(0)';
        }
      });
    }, observerOptions);

    // Aplicar a los elementos de servicio
    const elements = document.querySelectorAll<HTMLElement>('[data-aos]');
    elements.forEach((el) => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(30px)';
      el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      observer.observe(el);
    });
  });
</script>