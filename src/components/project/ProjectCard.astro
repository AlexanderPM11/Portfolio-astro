---
// src/components/project/ProjectCard.astro
import { Github, ExternalLink, ArrowUpRight } from "lucide-astro";
import { Icon } from "astro-icon/components";
import { techIcons } from "../../util/constants/TechIcons";

interface Props {
  id: number;
  title: string;
  category: string;
  description: string;
  image: string;
  techStack: string[];
  githubUrl?: string;
  liveUrl?: string;
}

const { id, title, category, description, image, techStack, githubUrl, liveUrl } = Astro.props;

// Tech Counter logic
const visibleTechCount = 4;
const mainTech = techStack?.slice(0, visibleTechCount) || [];
const remainingTech = techStack?.slice(visibleTechCount) || [];
const hasMore = remainingTech.length > 0;
---

<div
  class="group relative flex flex-col bg-[#0d0f14]/80 backdrop-blur-3xl border border-white/5 rounded-3xl overflow-hidden transition-all duration-500 hover:border-orange-500/30 hover:-translate-y-2 hover:shadow-[0_40px_80px_-20px_rgba(0,0,0,0.6),0_0_20px_-5px_rgba(249,115,22,0.1)] h-full"
  data-category={category}
>
  <!-- Image Banner (16:9 + Glossy Overlay) -->
  <div class="relative aspect-video m-2 rounded-2xl overflow-hidden bg-slate-800">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
    />
    <div class="absolute inset-0 bg-linear-to-t from-[#0d0f14] via-transparent to-transparent opacity-80"></div>
    
    <!-- Category Badge (Floating Glass) -->
    <div class="absolute top-3 left-3">
      <span class="px-3 py-1 bg-black/40 backdrop-blur-md border border-white/10 rounded-full text-[9px] uppercase font-black tracking-widest text-orange-500">
        {category}
      </span>
    </div>
  </div>

  <!-- Card Content -->
  <div class="p-5 pt-2 flex flex-col grow">
    <div class="mb-3">
       <h3 class="text-xl font-bold text-white group-hover:text-orange-400 transition-colors leading-tight" set:html={title} />
    </div>

    <!-- Description (Line-clamp initially, expand on hover) --!>
    <div class="relative overflow-hidden transition-all duration-500 max-h-10 group-hover:max-h-40">
      <p class="text-slate-400 text-xs leading-relaxed line-clamp-2 group-hover:line-clamp-none">
        {description}
      </p>
    </div>

    <!-- Tech Stack Row -->
    <div class="flex flex-wrap items-center gap-2 mt-auto pt-6 group-hover:pt-4 transition-all duration-500">
      {mainTech.map((tech) => {
        const iconData = techIcons[tech];
        return iconData ? (
          <div class="p-1.5 bg-white/5 border border-white/5 rounded-lg group/tech relative" title={iconData.title}>
            <Icon name={iconData.name} class="w-3.5 h-3.5" style={`color: ${iconData.color}`} />
          </div>
        ) : null;
      })}
      
      {hasMore && (
        <div class="flex items-center gap-2">
           <span class="text-[9px] font-black text-slate-500 bg-white/5 px-2 py-1.5 rounded-lg group-hover:hidden">
            +{remainingTech.length}
          </span>
          <!-- Revealed on Hover -->
          <div class="hidden group-hover:flex flex-wrap gap-2 animate-in fade-in slide-in-from-left-2 duration-300">
             {remainingTech.map((tech) => {
                const iconData = techIcons[tech];
                return iconData ? (
                  <div class="p-1.5 bg-white/5 border border-white/5 rounded-lg" title={iconData.title}>
                    <Icon name={iconData.name} class="w-3.5 h-3.5" style={`color: ${iconData.color}`} />
                  </div>
                ) : null;
             })}
          </div>
        </div>
      )}
    </div>

    <!-- Actions (Expandable on hover) -->
    <div class="flex items-center gap-3 mt-5 pt-4 border-t border-white/5 overflow-hidden">
      <!-- Details -->
      <a
        href={`/${id}`}
        class="flex items-center justify-center gap-2 h-9 px-3 bg-orange-500 text-white rounded-xl text-[10px] font-black uppercase tracking-wider group/btn shrink-0 hover:bg-orange-600 transition-all duration-300 active:scale-95"
      >
        <span class="hidden group-hover:block transition-all">Ver Más</span>
        <ArrowUpRight class="w-4 h-4" />
      </a>

      <!-- Source / Demo -->
      <div class="flex gap-2 ml-auto">
        {githubUrl && (
          <a
            href={githubUrl}
            target="_blank"
            class="flex items-center gap-2 h-9 px-3 bg-white/5 border border-white/10 text-slate-400 rounded-xl text-[10px] font-black uppercase tracking-wider hover:bg-white hover:text-black hover:w-auto w-9 transition-all duration-500 group/source"
            aria-label="GitHub"
          >
            <Github class="w-4 h-4 shrink-0" />
            <span class="opacity-0 group-hover/source:opacity-100 hidden group-hover/source:inline whitespace-nowrap">Source</span>
          </a>
        )}
        {liveUrl && (
          <a
            href={liveUrl}
            target="_blank"
            class="flex items-center gap-2 h-9 px-3 bg-white/5 border border-white/10 text-slate-400 rounded-xl text-[10px] font-black uppercase tracking-wider hover:bg-white hover:text-black hover:w-auto w-9 transition-all duration-500 group/demo"
            aria-label="Live Demo"
          >
            <ExternalLink class="w-4 h-4 shrink-0" />
            <span class="opacity-0 group-hover/demo:opacity-100 hidden group-hover/demo:inline whitespace-nowrap">Live</span>
          </a>
        )}
      </div>
    </div>
  </div>
</div>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
