---
// src/components/project/ProjectCard.astro
import { Github, ExternalLink, ArrowUpRight } from "lucide-astro";
import { Icon } from "astro-icon/components";
import { techIcons } from "../../util/constants/TechIcons";

interface Props {
  id: number;
  title: string;
  category: string;
  description: string;
  image: string;
  techStack: string[];
  githubUrl?: string;
  liveUrl?: string;
  size?: "small" | "medium" | "large"; // Bento sizes
}

const { id, title, category, description, image, techStack, githubUrl, liveUrl, size = "medium" } = Astro.props;

const isSmall = size === "small";
const isLarge = size === "large";

// Deterministic "code" snippet shown in hover background
const codeSnippet = `// ${title}
const config = {
  env: process.env.NODE_ENV,
  version: "1.0.0",
};

async function init() {
  const data = await fetch("/api");
  return data.json();
}

export default init;`;

const visibleTechCount = isLarge ? 8 : isSmall ? 0 : 4;
const mainTech = techStack?.slice(0, visibleTechCount) || [];
---

{isSmall ? (
  <!-- SMALL CELL: Just logo/image + name -->
  <div
    class="project-card group relative bg-[#0d0f14] border border-white/8 rounded-2xl overflow-hidden cursor-pointer transition-all duration-500 hover:border-orange-500/60 hover:-translate-y-1 hover:shadow-xl hover:shadow-orange-500/10 aspect-square flex flex-col"
    data-category={category}
    data-tech={techStack?.join(',')}
  >
    <!-- Code BG on hover -->
    <div class="code-bg absolute inset-0 opacity-0 group-hover:opacity-10 transition-opacity duration-700 font-mono text-[9px] text-orange-400 p-4 leading-relaxed overflow-hidden pointer-events-none select-none whitespace-pre">
      {codeSnippet}
    </div>

    <!-- Image fills the card -->
    <div class="relative flex-1 overflow-hidden">
      <img src={image} alt={title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
      <div class="absolute inset-0 bg-linear-to-t from-[#0d0f14] via-black/10 to-transparent"></div>
    </div>

    <!-- Bottom label -->
    <div class="p-4 relative z-10">
      <div class="flex items-center justify-between gap-2">
        <h3 class="text-sm font-bold text-white leading-tight line-clamp-2 group-hover:text-orange-400 transition-colors" set:html={title} />
        <a href={`/${id}`} class="p-1.5 bg-white/5 border border-white/10 rounded-lg text-white/40 hover:bg-orange-500 hover:text-white transition-all shrink-0">
          <ArrowUpRight class="w-3.5 h-3.5" />
        </a>
      </div>
      <span class="text-[9px] text-orange-500/70 font-bold uppercase tracking-widest mt-1 block">{category}</span>
    </div>
  </div>
) : isLarge ? (
  <!-- LARGE CELL: Full story card -->
  <div
    class="project-card group relative bg-[#0d0f14] border border-white/8 rounded-2xl overflow-hidden transition-all duration-500 hover:border-orange-500/60 hover:-translate-y-1 hover:shadow-2xl hover:shadow-orange-500/10 flex flex-col md:grid md:grid-cols-2 min-h-[480px]"
    data-category={category}
    data-tech={techStack?.join(',')}
  >
    <!-- Code BG on hover -->
    <div class="code-bg absolute inset-0 opacity-0 group-hover:opacity-[0.04] transition-opacity duration-700 font-mono text-[11px] text-orange-400 p-6 leading-relaxed overflow-hidden pointer-events-none select-none whitespace-pre z-0">
      {codeSnippet}
    </div>

    <!-- Left: Image -->
    <div class="relative overflow-hidden">
      <img src={image} alt={title} class="w-full h-full object-cover min-h-[220px] transition-transform duration-700 group-hover:scale-105" loading="lazy" />
      <div class="absolute inset-0 bg-linear-to-r from-transparent to-[#0d0f14] opacity-60 md:block hidden"></div>
      <div class="absolute inset-0 bg-linear-to-t from-[#0d0f14] via-transparent to-transparent md:hidden"></div>
      <!-- Category badge -->
      <div class="absolute top-4 left-4">
        <span class="px-3 py-1 bg-black/60 backdrop-blur-md border border-white/10 rounded-full text-[9px] font-black uppercase tracking-widest text-orange-400">
          {category}
        </span>
      </div>
    </div>

    <!-- Right: Content -->
    <div class="p-8 flex flex-col justify-between relative z-10">
      <div>
        <h3 class="text-3xl font-black text-white leading-tight mb-3 group-hover:text-orange-400 transition-colors" set:html={title} />
        <div class="w-12 h-1 bg-orange-500 rounded-full mb-5 transition-all duration-500 group-hover:w-24"></div>
        <p class="text-slate-400 text-sm leading-relaxed mb-6">{description}</p>
      </div>

      <!-- Tech Stack -->
      <div class="flex flex-wrap gap-2 mb-8">
        {mainTech.map((tech) => {
          const iconData = techIcons[tech];
          return iconData ? (
            <div class="flex items-center gap-1.5 px-3 py-1.5 bg-white/5 border border-white/8 rounded-xl group/t hover:border-orange-500/30 transition-all" title={tech}>
              <Icon name={iconData.name} class="w-3.5 h-3.5" style={`color: ${iconData.color}`} />
              <span class="text-[10px] font-bold text-slate-400 group-hover/t:text-white transition-colors">{tech}</span>
            </div>
          ) : null;
        })}
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-3">
        {githubUrl && (
          <a href={githubUrl} target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-2 px-4 py-2.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl text-[10px] font-bold uppercase tracking-widest text-white/60 hover:text-white transition-all">
            <Github class="w-4 h-4" />
            <span>GitHub</span>
          </a>
        )}
        {liveUrl && (
          <a href={liveUrl} target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-2 px-5 py-2.5 bg-orange-500 hover:bg-orange-600 rounded-xl text-[10px] font-black uppercase tracking-widest text-white transition-all shadow-lg shadow-orange-500/20 active:scale-95 ml-auto">
            <ExternalLink class="w-4 h-4" />
            <span>Demo Live</span>
          </a>
        )}
      </div>
    </div>
  </div>
) : (
  <!-- MEDIUM CELL: Standard card -->
  <div
    class="project-card group relative bg-[#0d0f14] border border-white/8 rounded-2xl overflow-hidden transition-all duration-500 hover:border-orange-500/60 hover:-translate-y-1 hover:shadow-xl hover:shadow-orange-500/10 flex flex-col"
    data-category={category}
    data-tech={techStack?.join(',')}
  >
    <!-- Code BG on hover -->
    <div class="code-bg absolute inset-0 opacity-0 group-hover:opacity-[0.05] transition-opacity duration-700 font-mono text-[10px] text-orange-400 p-5 leading-relaxed overflow-hidden pointer-events-none select-none whitespace-pre z-0">
      {codeSnippet}
    </div>

    <!-- Image -->
    <div class="relative aspect-video overflow-hidden shrink-0">
      <img src={image} alt={title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
      <div class="absolute inset-0 bg-linear-to-t from-[#0d0f14] via-transparent to-transparent opacity-80"></div>
      <div class="absolute top-3 left-3">
        <span class="px-2.5 py-1 bg-black/60 backdrop-blur-md border border-white/10 rounded-full text-[8px] font-black uppercase tracking-widest text-white/70 group-hover:text-orange-400 transition-colors">
          {category}
        </span>
      </div>
    </div>

    <!-- Content -->
    <div class="p-5 flex flex-col grow relative z-10">
      <div class="flex items-start justify-between gap-2 mb-3">
        <h3 class="text-lg font-bold text-white leading-snug group-hover:text-orange-400 transition-colors" set:html={title} />
        <a href={`/${id}`} class="p-1.5 bg-white/5 border border-white/10 rounded-lg text-white/40 hover:bg-orange-500 hover:text-white transition-all shrink-0">
          <ArrowUpRight class="w-3.5 h-3.5" />
        </a>
      </div>

      <p class="text-slate-400 text-xs leading-relaxed line-clamp-2 mb-5">{description}</p>

      <!-- Tech icons -->
      <div class="flex flex-wrap gap-1.5 mb-6">
        {mainTech.map((tech) => {
          const iconData = techIcons[tech];
          return iconData ? (
            <div class="p-1.5 bg-white/5 border border-white/5 rounded-lg" title={tech}>
              <Icon name={iconData.name} class="w-3.5 h-3.5 opacity-60 group-hover:opacity-100 transition-opacity" style={`color: ${iconData.color}`} />
            </div>
          ) : null;
        })}
      </div>

      <!-- Action bar -->
      <div class="mt-auto pt-4 border-t border-white/5 flex gap-2">
        {githubUrl && (
          <a href={githubUrl} target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-1.5 px-3 py-2 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl text-[9px] font-bold uppercase tracking-widest text-white/60 hover:text-white transition-all">
            <Github class="w-3.5 h-3.5" />
            <span>GitHub</span>
          </a>
        )}
        {liveUrl && (
          <a href={liveUrl} target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-1.5 px-3 py-2 bg-orange-500 hover:bg-orange-600 rounded-xl text-[9px] font-black uppercase tracking-widest text-white transition-all ml-auto shadow-lg shadow-orange-500/20 active:scale-95">
            <ExternalLink class="w-3.5 h-3.5" />
            <span>Demo</span>
          </a>
        )}
      </div>
    </div>
  </div>
)}

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
