---
// src/components/project/Projects.astro
import { GetProjects } from "../../services/blog/ProjectService";
import type { ProjectPost } from "../../interface/Project/ProjectInterface";
import SectionHeading from "../common/SectionHeading.astro";
import { Icon } from "astro-icon/components";
import { techIcons } from "../../util/constants/TechIcons";
import { Github, ExternalLink, ArrowUpRight, ChevronLeft, ChevronRight } from "lucide-astro";

let projects: ProjectPost[] = [];
let categories = ["all"];
let technologies: string[] = ["all"];
let fetchError = false;

try {
  projects = await GetProjects();
  categories = ["all", ...new Set(projects.map((p) => p.category || "general"))];

  const allTechs = projects.flatMap(p => p.techStack || []);
  const techCounts = allTechs.reduce((acc, tech) => {
    acc[tech] = (acc[tech] || 0) + 1;
    return acc;
  }, {} as Record<string, number>);
  const filteredTechs = Object.entries(techCounts)
    .sort(([, a], [, b]) => b - a)
    .slice(0, 12)
    .map(([tech]) => tech);
  technologies = ["all", ...filteredTechs];
} catch (err) {
  console.error("Error cargando proyectos:", err);
  fetchError = true;
}
---

<section id="projects" class="py-24 bg-gray-900 text-white relative overflow-hidden">
  <!-- Ambient top glow -->
  <div class="absolute inset-x-0 -top-40 h-[800px] bg-[radial-gradient(ellipse_at_50%_0%,rgba(249,115,22,0.07),transparent_70%)] pointer-events-none"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="flex flex-col w-full items-center">
      <SectionHeading
        label="Proyectos"
        title="Proyectos"
        highlight="Destacados"
        description="Selección de trabajos recientes que combinan tecnología de vanguardia con un diseño de alta gama."
      />
    </div>

    <!-- Section divider with embedded mode switcher -->
    <div class="relative flex items-center gap-4 mb-8">
      <div class="flex-1 h-px bg-linear-to-r from-transparent via-white/10 to-transparent"></div>
      <!-- Mode Switcher in the divider -->
      <div class="flex p-1 bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl shrink-0">
        <button id="mode-cat" class="mode-btn px-5 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all duration-300 bg-orange-500 text-white shadow-lg" data-mode="category">
          Categorías
        </button>
        <button id="mode-tech" class="mode-btn px-5 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all duration-300 text-gray-400 hover:text-white" data-mode="tech">
          Tecnologías
        </button>
      </div>
      <div class="flex-1 h-px bg-linear-to-r from-transparent via-white/10 to-transparent"></div>
    </div>

    {fetchError ? (
      <div class="max-w-md mx-auto bg-red-900/10 border border-red-500/20 rounded-2xl p-6 text-center">
        <p class="text-red-300 font-medium italic">Hubo un problema al cargar los proyectos activos.</p>
      </div>
    ) : (
      <>
        <!-- Category Filter Bar + Counter (same row on desktop, stacked on mobile) -->
        <div id="filter-categories" class="filter-container flex flex-wrap md:flex-nowrap items-center gap-3 mb-6">
          <!-- Scrollable pills strip -->
          <div class="flex gap-2 overflow-x-auto scrollbar-hide w-full md:flex-1 md:min-w-0 py-1">
            {categories.map((cat) => (
              <button
                class={`filter-btn shrink-0 px-5 py-2 rounded-2xl text-[10px] font-black uppercase tracking-[0.3em] transition-all duration-300 border ${
                  cat === "all"
                    ? "bg-orange-500 border-orange-500 text-white shadow-[0_8px_20px_-5px_rgba(249,115,22,0.4)]"
                    : "bg-white/5 border-white/5 text-gray-400 hover:text-white hover:bg-white/10"
                }`}
                data-type="category"
                data-value={cat}
              >
                {cat === "all" ? "Todos" : cat}
              </button>
            ))}
          </div>
          <!-- Counter + Arrows (always visible, never pushed down) -->
          <div class="flex items-center gap-3 shrink-0">
            <span class="text-[10px] text-gray-500 font-bold uppercase tracking-[0.2em]">
              <span id="slide-current">01</span> / <span id="slide-total">{String(projects.length).padStart(2, '0')}</span>
            </span>
            <div class="flex gap-2">
              <button id="prev-btn" class="p-2.5 bg-white/5 border border-white/10 rounded-xl text-white/50 hover:bg-orange-500 hover:text-white hover:border-orange-500 transition-all">
                <ChevronLeft class="w-4 h-4" />
              </button>
              <button id="next-btn" class="p-2.5 bg-white/5 border border-white/10 rounded-xl text-white/50 hover:bg-orange-500 hover:text-white hover:border-orange-500 transition-all">
                <ChevronRight class="w-4 h-4" />
              </button>
            </div>
          </div>
        </div>

        <!-- Tech Filter Bar + Counter (same row on desktop, stacked on mobile, hidden by default) -->
        <div id="filter-technologies" class="filter-container hidden flex-wrap md:flex-nowrap items-center gap-3 mb-6">
          <!-- Scrollable pills strip -->
          <div class="flex gap-2 overflow-x-auto scrollbar-hide w-full md:flex-1 md:min-w-0 py-1">
            {technologies.map((tech) => (
              <button
                class={`filter-btn shrink-0 px-5 py-2 rounded-2xl text-[10px] font-black uppercase tracking-[0.3em] transition-all duration-300 border ${
                  tech === "all"
                    ? "bg-orange-500 border-orange-500 text-white shadow-[0_8px_20px_-5px_rgba(249,115,22,0.4)]"
                    : "bg-white/5 border-white/5 text-gray-400 hover:text-white hover:bg-white/10"
                }`}
                data-type="tech"
                data-value={tech}
              >
                {tech === "all" ? "Todas" : tech}
              </button>
            ))}
          </div>
          <!-- Counter + Arrows -->
          <div class="flex items-center gap-3 shrink-0">
            <span class="text-[10px] text-gray-500 font-bold uppercase tracking-[0.2em]">
              <span class="slide-current-mirror">01</span> / <span class="slide-total-mirror">{String(projects.length).padStart(2, '0')}</span>
            </span>
            <div class="flex gap-2">
              <button class="prev-btn-mirror p-2.5 bg-white/5 border border-white/10 rounded-xl text-white/50 hover:bg-orange-500 hover:text-white hover:border-orange-500 transition-all">
                <ChevronLeft class="w-4 h-4" />
              </button>
              <button class="next-btn-mirror p-2.5 bg-white/5 border border-white/10 rounded-xl text-white/50 hover:bg-orange-500 hover:text-white hover:border-orange-500 transition-all">
                <ChevronRight class="w-4 h-4" />
              </button>
            </div>
          </div>
        </div>

        <!-- Filter → Slider divider -->
        <div class="relative mb-8">
          <div class="h-px w-full bg-linear-to-r from-orange-500/30 via-white/5 to-orange-500/30"></div>
          <div class="absolute left-1/2 -translate-x-1/2 -top-px h-px w-1/3 bg-orange-500/20 blur-sm"></div>
        </div>

        <!-- Horizontal Showcase Slider -->
        <div class="relative">
          <!-- Dynamic blur background (changes per slide) -->
          <div id="slider-bg" class="absolute -inset-20 opacity-30 transition-all duration-1000 pointer-events-none blur-[80px] rounded-full"
            style={`background-image: url('${projects[0]?.image}'); background-size: cover; background-position: center;`}
          ></div>

          <!-- Slider Track -->
          <div
            id="slider-track"
            class="relative flex overflow-x-auto snap-x snap-mandatory gap-6 pb-4 scrollbar-hide"
            style="scroll-behavior: smooth;"
          >
            {projects.map((project, index) => {
              const mainTech = project.techStack?.slice(0, 6) || [];
              return (
                <div
                  class="slide group snap-center shrink-0 w-full md:w-[88%] lg:w-[78%] relative rounded-3xl overflow-hidden border border-white/8 bg-[#0d0f14] transition-all duration-700 cursor-pointer hover:border-orange-500/40 hover:shadow-[0_0_60px_-15px_rgba(249,115,22,0.25)] hover:-translate-y-1"
                  data-category={project.category}
                  data-tech={project.techStack?.join(',')}
                  data-index={index}
                  style="min-height: 520px;"
                >
                  <!-- Full-bleed blurred BG from project image (intensifies on hover) -->
                  <div class="absolute inset-0 overflow-hidden">
                    <img
                      src={project.image}
                      alt=""
                      class=" absolute inset-0 w-full h-full object-cover scale-110 blur-2xl opacity-20 saturate-150 transition-all duration-700 group-hover:opacity-35 group-hover:scale-105"
                      aria-hidden="true"
                    />
                    <div class="absolute inset-0 bg-linear-to-r from-[#0d0f14] via-[#0d0f14]/90 to-[#0d0f14]/60"></div>
                  </div>

                  <!-- Orange halo line on top edge -->
                  <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-orange-500/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                  <!-- Content Grid: stacked on mobile, side-by-side on desktop -->
                  <div class="relative z-10 flex flex-col md:grid md:grid-cols-2 h-full min-h-[520px]">
                    <!-- Left: Text Content -->
                    <div class="p-6 md:p-10 lg:p-14 flex flex-col justify-center order-last md:order-first">
                      <!-- Index + Category -->
                      <div class="flex items-center gap-3 mb-8">
                        <span class="text-[10px] font-black text-white/20 tracking-[0.4em] uppercase">
                          {String(index + 1).padStart(2, '0')}
                        </span>
                        <div class="w-8 h-px bg-white/20"></div>
                        <span class="px-3 py-1 bg-orange-500/10 border border-orange-500/30 rounded-full text-[9px] font-black uppercase tracking-widest text-orange-400">
                          {project.category}
                        </span>
                      </div>

                      <!-- Title -->
                      <a href={`/${project.id}`} class="group/title block mb-5">
                        <h3
                          class="text-2xl lg:text-3xl font-black text-white leading-[1.1] tracking-tight transition-colors duration-500 group-hover:text-orange-400 group-hover/title:text-orange-400"
                          set:html={project.title.rendered}
                        />
                      </a>

                      <!-- Separator (expands on hover) -->
                      <div class="w-12 h-1 bg-orange-500 rounded-full mb-6 transition-all duration-700 group-hover:w-24"></div>

                      <!-- Description -->
                      <p class="text-slate-300/80 text-base leading-relaxed mb-10 max-w-sm">
                        {project.description.rendered.replace(/<[^>]*>/g, '').slice(0, 200)}{project.description.rendered.replace(/<[^>]*>/g, '').length > 160 ? '…' : ''}
                      </p>

                      <!-- Tech Stack -->
                      <div class="flex flex-wrap gap-2 mb-10">
                        {mainTech.map((tech) => {
                          const iconData = techIcons[tech];
                          return iconData ? (
                            <div class="flex items-center gap-2 px-3 py-1.5 bg-white/5 border border-white/8 rounded-xl transition-all duration-300 group-hover:border-orange-500/20 group-hover:bg-orange-500/5">
                              <Icon name={iconData.name} class="w-3.5 h-3.5" style={`color: ${iconData.color}`} />
                              <span class="text-[10px] font-bold text-slate-400 group-hover:text-slate-300 transition-colors">{tech}</span>
                            </div>
                          ) : null;
                        })}
                      </div>

                      <!-- Action Buttons -->
                      <div class="flex items-center gap-3 flex-wrap">
                        {project.acf?.githubUrl && (
                          <a
                            href={project.acf.githubUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="flex items-center gap-2 px-5 py-3 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/30 rounded-2xl text-[11px] font-black uppercase tracking-widest text-white/60 hover:text-white transition-all hover:-translate-y-0.5 active:scale-95"
                          >
                            <Github class="w-4 h-4" />
                            <span>GitHub</span>
                          </a>
                        )}
                        {project.acf?.liveurl && (
                          <a
                            href={project.acf.liveurl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="flex items-center gap-2 px-6 py-3 bg-orange-500 hover:bg-orange-400 rounded-2xl text-[11px] font-black uppercase tracking-widest text-white transition-all shadow-[0_15px_30px_-8px_rgba(249,115,22,0.4)] hover:shadow-[0_20px_40px_-8px_rgba(249,115,22,0.6)] hover:-translate-y-0.5 active:scale-95"
                          >
                            <ExternalLink class="w-4 h-4" />
                            <span>Demo Live</span>
                          </a>
                        )}
                        <a
                          href={`/${project.id}`}
                          class="flex items-center gap-2 px-5 py-3 border border-white/10 rounded-2xl text-[11px] font-black uppercase tracking-widest text-white/40 hover:text-white hover:border-white/30 transition-all"
                        >
                          <ArrowUpRight class="w-4 h-4" />
                          <span>Ver más</span>
                        </a>
                      </div>
                    </div>

                    <!-- RIGHT (desktop) / TOP (mobile): Project Image -->
                    <div class="relative overflow-hidden flex items-center justify-center p-5 md:p-8 order-first md:order-last">
                      <div class="slide-img relative w-full h-full max-h-[400px] rounded-2xl overflow-hidden shadow-2xl border border-white/10 transition-all duration-700 group-hover:border-orange-500/30 group-hover:shadow-[0_30px_60px_-15px_rgba(0,0,0,0.8)]">
                        <img
                          src={project.image}
                          alt={project.title.rendered}
                          class="w-full h-full object-cover min-h-[320px] transition-transform duration-[2s] ease-out group-hover:scale-110"
                          loading="lazy"
                        />
                        <!-- Overlay tint that fades on hover -->
                        <div class="absolute inset-0 bg-linear-to-br from-orange-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                      </div>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>

          <!-- Dot Navigation -->
          <div class="flex justify-center gap-2 mt-6" id="dot-nav">
            {projects.map((_, i) => (
              <button
                class={`dot-btn w-2 h-2 rounded-full transition-all duration-300 ${i === 0 ? 'bg-orange-500 w-6' : 'bg-white/20 hover:bg-white/40'}`}
                data-slide-index={i}
              ></button>
            ))}
          </div>
        </div>

        {projects.length === 0 && (
          <div class="text-center py-24 border-t border-white/5 mt-8">
            <p class="text-gray-500 text-xs uppercase tracking-[0.4em]">Sin proyectos en esta sección</p>
          </div>
        )}
      </>
    )}
  </div>
</section>

<script>
  // ── Slider Logic ──────────────────────────────────────────────
  const track = document.getElementById('slider-track') as HTMLElement;
  const slides = document.querySelectorAll('.slide') as NodeListOf<HTMLElement>;
  const dots = document.querySelectorAll('.dot-btn') as NodeListOf<HTMLButtonElement>;
  const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  const currentLabel = document.getElementById('slide-current') as HTMLElement;
  const sliderBg = document.getElementById('slider-bg') as HTMLElement;

  let currentIndex = 0;

  // Get visible (non-filtered) slides
  function getVisibleSlides(): HTMLElement[] {
    return Array.from(slides).filter(s => !s.classList.contains('filtered-out'));
  }

  function scrollToSlide(index: number) {
    const visible = getVisibleSlides();
    if (!visible.length) return;
    index = Math.max(0, Math.min(index, visible.length - 1));
    currentIndex = index;
    
    visible[index].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });

    // Dynamic background
    const imgSrc = (visible[index].querySelector('.slide-img img') as HTMLImageElement)?.src || '';
    if (sliderBg) {
      sliderBg.style.backgroundImage = `url('${imgSrc}')`;
    }

    // Counter (main + mirrors)
    if (currentLabel) currentLabel.textContent = String(index + 1).padStart(2, '0');
    document.querySelectorAll('.slide-current-mirror').forEach(el => el.textContent = String(index + 1).padStart(2, '0'));

    // Dots
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-orange-500', i === index);
      dot.classList.toggle('w-6', i === index);
      dot.classList.toggle('bg-white/20', i !== index);
      dot.classList.toggle('w-2', i !== index);
    });
  }

  prevBtn?.addEventListener('click', () => scrollToSlide(currentIndex - 1));
  nextBtn?.addEventListener('click', () => scrollToSlide(currentIndex + 1));

  // Mirror buttons (tech tab)
  document.querySelectorAll('.prev-btn-mirror').forEach(btn => btn.addEventListener('click', () => scrollToSlide(currentIndex - 1)));
  document.querySelectorAll('.next-btn-mirror').forEach(btn => btn.addEventListener('click', () => scrollToSlide(currentIndex + 1)));

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const idx = parseInt(dot.dataset.slideIndex || '0');
      scrollToSlide(idx);
    });
  });

  // Keyboard
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight') scrollToSlide(currentIndex + 1);
    if (e.key === 'ArrowLeft') scrollToSlide(currentIndex - 1);
  });

  // Snap scroll observer
  let scrollTimer: ReturnType<typeof setTimeout>;
  track?.addEventListener('scroll', () => {
    clearTimeout(scrollTimer);
    scrollTimer = setTimeout(() => {
      const visible = getVisibleSlides();
      visible.forEach((slide, i) => {
        const rect = slide.getBoundingClientRect();
        const trackRect = track.getBoundingClientRect();
        const slideCenter = rect.left + rect.width / 2;
        const trackCenter = trackRect.left + trackRect.width / 2;
        if (Math.abs(slideCenter - trackCenter) < rect.width / 2) {
          if (currentIndex !== i) scrollToSlide(i);
        }
      });
    }, 100);
  });

  // ── Filter Logic ──────────────────────────────────────────────
  const modeBtns = document.querySelectorAll('.mode-btn') as NodeListOf<HTMLButtonElement>;
  const filterBtns = document.querySelectorAll('.filter-btn') as NodeListOf<HTMLButtonElement>;
  const filterContainers = document.querySelectorAll('.filter-container') as NodeListOf<HTMLElement>;
  const totalLabel = document.getElementById('slide-total') as HTMLElement;

  let activeMode = 'category';

  modeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const mode = btn.dataset.mode || 'category';
      if (mode === activeMode) return;
      activeMode = mode;
      modeBtns.forEach(b => { b.classList.remove('bg-orange-500', 'text-white', 'shadow-lg'); b.classList.add('text-gray-400'); });
      btn.classList.add('bg-orange-500', 'text-white', 'shadow-lg'); btn.classList.remove('text-gray-400');
      filterContainers.forEach(c => { c.classList.add('hidden'); c.classList.remove('flex'); });
      const target = document.getElementById(`filter-${mode === 'category' ? 'categories' : 'technologies'}`);
      if (target) { target.classList.remove('hidden'); target.classList.add('flex'); }
      resetFilters();
    });
  });

  function resetFilters() {
    slides.forEach(s => { s.classList.remove('filtered-out'); s.style.display = ''; });
    filterBtns.forEach(b => {
      b.classList.remove('bg-orange-500', 'border-orange-500', 'text-white', 'shadow-[0_8px_20px_-5px_rgba(249,115,22,0.4)]');
      b.classList.add('bg-white/5', 'border-white/5', 'text-gray-400');
      if (b.dataset.value === 'all') {
        b.classList.add('bg-orange-500', 'border-orange-500', 'text-white', 'shadow-[0_8px_20px_-5px_rgba(249,115,22,0.4)]');
        b.classList.remove('bg-white/5', 'border-white/5', 'text-gray-400');
      }
    });
    updateTotal();
    scrollToSlide(0);
  }

  function updateTotal() {
    if (totalLabel) totalLabel.textContent = String(getVisibleSlides().length).padStart(2, '0');
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const type = btn.dataset.type;
      const value = btn.dataset.value || 'all';
      const siblings = Array.from(filterBtns).filter(b => b.dataset.type === type);
      siblings.forEach(b => {
        b.classList.remove('bg-orange-500', 'border-orange-500', 'text-white', 'shadow-[0_8px_20px_-5px_rgba(249,115,22,0.4)]');
        b.classList.add('bg-white/5', 'border-white/5', 'text-gray-400');
      });
      btn.classList.add('bg-orange-500', 'border-orange-500', 'text-white', 'shadow-[0_8px_20px_-5px_rgba(249,115,22,0.4)]');
      btn.classList.remove('bg-white/5', 'border-white/5', 'text-gray-400');

      slides.forEach(slide => {
        const cat = slide.dataset.category || '';
        const techs = (slide.dataset.tech || '').split(',');
        let show = value === 'all' || (type === 'category' && cat === value) || (type === 'tech' && techs.includes(value));
        slide.classList.toggle('filtered-out', !show);
        slide.style.display = show ? '' : 'none';
      });
      updateTotal();
      scrollToSlide(0);
    });
  });
</script>

<style>
  #slider-track {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #slider-track::-webkit-scrollbar {
    display: none;
  }
  /* Hide scrollbar on filter pill strips */
  .filter-container .overflow-x-auto {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .filter-container .overflow-x-auto::-webkit-scrollbar {
    display: none;
  }
  /* Ensure filter containers show as flex when JS adds the class */
  .filter-container.flex {
    display: flex !important;
    align-items: center;
  }
  @media (min-width: 768px) {
    .filter-container.flex {
      flex-wrap: nowrap;
    }
  }
  .slide {
    transition: opacity 0.4s, transform 0.7s cubic-bezier(0.2,0,0,1), border-color 0.5s, box-shadow 0.7s;
  }
  .slide.filtered-out {
    display: none;
  }
</style>