---
// src/components/project/Projects.astro
import { GetProjects } from "../../services/blog/ProjectService";
import type { ProjectPost } from "../../interface/Project/ProjectInterface";
import SectionHeading from "../common/SectionHeading.astro";
import ProjectCard from "./ProjectCard.astro";

let projects: ProjectPost[] = [];
let categories = ["all"];
let fetchError = false;

try {
  projects = await GetProjects();
  categories = ["all", ...new Set(projects.map((p) => p.category || "general"))];
} catch (err) {
  console.error("Error cargando proyectos:", err);
  fetchError = true;
}
---

<section id="projects" class="py-24 bg-[#0a0a0c] text-white relative overflow-hidden">
  <!-- Dynamic Aura Background -->
  <div class="absolute inset-x-0 -top-40 h-[1000px] bg-[radial-gradient(circle_at_50%_0%,rgba(249,115,22,0.06),transparent_80%)] pointer-events-none"></div>
  
  <div class="container mx-auto px-6 relative z-10">
    <div class="flex flex-col w-full items-start animate-in fade-in slide-in-from-bottom-5 duration-700">
      <SectionHeading
        label="Proyectos"
        title="Proyectos"
        highlight="Destacados"
        description="Selección de trabajos recientes que combinan tecnología de vanguardia con un diseño de alta gama."
      />
    </div>

    {fetchError ? (
      <div class="max-w-md mx-auto bg-red-900/10 backdrop-blur-sm border border-red-500/20 rounded-2xl p-6 text-center">
        <p class="text-red-300 font-medium italic">Hubo un problema al cargar los proyectos activos.</p>
      </div>
    ) : (
      <>
        <!-- Modern SaaS Chip Filter Bar -->
        <div id="filter-tabs" class="flex flex-wrap gap-2 mb-16 animate-in fade-in slide-in-from-bottom-4 duration-700 delay-200">
          {categories.map((cat) => (
            <button
              class={`filter-btn px-6 py-2 rounded-2xl text-[10px] font-black uppercase tracking-[0.3em] transition-all duration-500 border ${
                cat === "all" 
                  ? "bg-orange-500 border-orange-500 text-white shadow-[0_10px_20px_-5px_rgba(249,115,22,0.3)]" 
                  : "bg-white/5 border-white/5 text-gray-400 hover:text-white hover:bg-white/10"
              }`}
              data-category={cat}
            >
              {cat === "all" ? "Todos" : cat}
            </button>
          ))}
        </div>

        <!-- Compact Project Grid (4-cols) -->
        <div id="projects-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8 items-stretch">
          {projects.map((project) => (
            <ProjectCard
              id={project.id}
              title={project.title.rendered}
              category={project.category}
              description={project.description.rendered.replace(/<[^>]*>/g, '')}
              image={project.image}
              techStack={project.techStack}
              githubUrl={project.acf?.githubUrl}
              liveUrl={project.acf?.liveurl}
            />
          ))}
        </div>

        {projects.length === 0 && (
          <div class="text-center py-32 border-t border-white/5">
            <p class="text-gray-500 text-xs uppercase tracking-[0.4em] animate-pulse">Sin proyectos en esta sección</p>
          </div>
        )}
      </>
    )}
  </div>
</section>

<script>
  const buttons = document.querySelectorAll(".filter-btn") as NodeListOf<HTMLButtonElement>;
  const cards = document.querySelectorAll("[data-category]") as NodeListOf<HTMLElement>;

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const category = btn.dataset.category || "all";
      
      // Update Button Styles
      buttons.forEach((b) => {
        b.classList.remove("bg-orange-500", "border-orange-500", "text-white", "shadow-[0_10px_20px_-5px_rgba(249,115,22,0.3)]");
        b.classList.add("bg-white/5", "border-white/5", "text-gray-400");
      });

      btn.classList.add("bg-orange-500", "border-orange-500", "text-white", "shadow-[0_10px_20px_-5px_rgba(249,115,22,0.3)]");
      btn.classList.remove("bg-white/5", "border-white/5", "text-gray-400");

      // Filter Cards
      cards.forEach((card) => {
        // Only target the top-level project card div
        if (!card.classList.contains('group')) return;

        const cardCat = card.dataset.category || "all";
        if (category === "all" || cardCat === category) {
          card.classList.remove("hidden");
          card.style.opacity = "0";
          setTimeout(() => card.style.opacity = "1", 50);
        } else {
          card.classList.add("hidden");
        }
      });
    });
  });
</script>

<style>
  [data-category] {
    transition: opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>