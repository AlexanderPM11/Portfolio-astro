---
import { ExternalLink, Calendar, ArrowLeft, Clock } from "lucide-astro";
import { sanitizeContent } from "../../util/constants/sanitizedContent";
import Layout from "../../layouts/Layout.astro";
import { getProjectById } from "../../services/blog/ProjectService";
import type { ProjectPost } from "../../interface/Project/ProjectInterface";
import { getPostPaths } from "../../services/blog/BlogService";
import BlogSidebar from "../../components/blog/BlogSidebar.astro";

const { id } = Astro.params;

export async function getStaticPaths() {
  return await getPostPaths();
}

export async function get(id: string) {
  if (!id) throw new Error("ID no proporcionado");
  try {
    const post = await getProjectById(Number(id));
    return { props: { post } };
  } catch {
    return { props: { post: null } };
  }
}

let post: ProjectPost;
const data = await get(id);
post = data.props.post!;

const sanitizedContent = sanitizeContent(post.content?.rendered || "");

const formatDate = (d: string) =>
  new Date(d).toLocaleDateString("es-ES", { year: "numeric", month: "long", day: "numeric" });

// Estimate reading time
const wordCount = (post.content?.rendered || "").replace(/<[^>]*>/g, "").split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const categories = post.categories || (post.category ? [post.category] : []);
---

<Layout>
  <!-- Reading Progress Bar -->
  <div id="progress-bar" class="fixed top-0 inset-x-0 h-[3px] bg-orange-500 z-[9999] origin-left scale-x-0 transition-transform duration-100 ease-linear"></div>

  <main class="bg-[#0a0a0c] text-white pt-28 pb-20">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        
        <!-- Main Content Area -->
        <article class="lg:col-span-8 flex flex-col gap-8 lg:border-r lg:border-gray-800 lg:pr-12">
          
          <!-- Image Section -->
          {post.image && (
            <div class="relative group">
              <div class="rounded-2xl overflow-hidden border border-gray-800 shadow-2xl">
                <img
                  src={post.image}
                  alt={post.title.rendered}
                  class="w-full object-cover max-h-[500px] transition-transform duration-700 group-hover:scale-105"
                  loading="eager"
                />
                <div class="absolute inset-0 bg-linear-to-t from-black/60 via-transparent to-transparent"></div>
              </div>
              
              <!-- Category Badges (Orange Boxes style for brand consistency) -->
              <div class="absolute bottom-0 left-0 p-4 flex flex-wrap gap-2 z-10">
                {categories.map((cat) => (
                  <span class="px-4 py-2 bg-orange-500 text-white text-[10px] font-black uppercase tracking-widest shadow-lg">
                    {cat}
                  </span>
                ))}
              </div>
            </div>
          )}

          <!-- Post Header Info -->
          <header class="flex flex-col gap-4">
            <!-- Date -->
            <div class="flex items-center gap-2 text-gray-500 text-xs font-bold uppercase tracking-tighter">
              <span class="text-orange-500">_</span> {formatDate(post.date)}
            </div>

            <!-- Title -->
            <h1
              class="text-4xl md:text-5xl font-extrabold leading-tight tracking-tight text-white group-hover:text-orange-400 transition-colors"
              set:html={post.title.rendered}
            />

            <!-- Short Excerpt / Description -->
            {post.description?.rendered && (
              <p class="text-lg text-gray-400 leading-relaxed border-l-2 border-orange-500/30 pl-6 italic">
                {post.description.rendered.replace(/<[^>]*>/g, "").slice(0, 250)}...
              </p>
            )}
          </header>

          <!-- Divider -->
          <div class="h-px bg-gray-800 w-full"></div>

          <!-- Body Content -->
          <div class="post-content-container">
            <div class="post-content prose-premium" set:html={sanitizedContent} />
          </div>

          <!-- Social / Footer info -->
          <footer class="flex items-center justify-between border-t border-gray-800 pt-8 mt-8">
            <div class="flex items-center gap-4 text-orange-400 font-bold text-sm uppercase tracking-wider">
              <ArrowLeft class="w-4 h-4" />
              <a href="/blog" class="hover:text-orange-300 transition-colors">Volver al blog</a>
            </div>
            
            <div class="flex items-center gap-6 text-gray-500">
               <div class="flex items-center gap-2">
                 <Clock class="w-4 h-4" />
                 <span class="text-xs">{readingTime} MIN</span>
               </div>
               <div class="flex items-center gap-2">
                 <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                 <span class="text-xs">272</span>
               </div>
            </div>
          </footer>

          <!-- CTA Section -->
          <section class="mt-16 bg-[#111318] border border-gray-800 rounded-3xl p-10 relative overflow-hidden text-center">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(249,115,22,0.05),transparent_50%)] pointer-events-none"></div>
            
            <div class="relative z-10">
              <h2 class="text-2xl md:text-3xl font-black text-white mb-4">¿Te resultó interesante este contenido?</h2>
              <p class="text-gray-400 mb-8 max-w-xl mx-auto">Si deseas obtener más información, colaborar o compartir tus ideas, estaré encantado de escucharte.</p>
              <a
                href="/#contact"
                class="inline-flex items-center gap-3 px-8 py-4 bg-orange-500 hover:bg-orange-600 text-white font-black rounded-2xl transition-all shadow-[0_0_20px_rgba(249,115,22,0.3)] hover:scale-105"
              >
                CONTACTAR
                <ExternalLink class="w-5 h-5" />
              </a>
            </div>
          </section>
        </article>

        <!-- Sidebar -->
        <div class="lg:col-span-4">
          <BlogSidebar />
        </div>

      </div>
    </div>
  </main>
</Layout>

<script>
  const bar = document.getElementById("progress-bar");
  if (bar) {
    window.addEventListener("scroll", () => {
      const scrollTop = document.documentElement.scrollTop;
      const docHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const progress = docHeight > 0 ? scrollTop / docHeight : 0;
      bar.style.transform = `scaleX(${progress})`;
    }, { passive: true });
  }
</script>

<style>
  /* ── Post Content Prose Styles (Modern Premium) ──────────────── */
  .post-content-container {
    max-width: none;
  }

  .prose-premium {
    color: #d1d5db; /* text-gray-300 */
    line-height: 1.8;
    font-size: 1.125rem; /* text-lg */
  }

  .prose-premium h2, .prose-premium h3 {
    color: white;
    font-weight: 900;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    letter-spacing: -0.025em;
  }
  .prose-premium h2 { font-size: 1.875rem; } /* text-3xl */
  .prose-premium h3 { font-size: 1.5rem; }    /* text-2xl */

  .prose-premium p { margin-bottom: 1.5rem; }

  .prose-premium a {
    color: #f97316; /* text-orange-500 */
    text-decoration: underline;
    text-decoration-color: rgba(249, 115, 22, 0.3);
    text-underline-offset: 4px;
    transition: color 0.2s;
  }
  .prose-premium a:hover { color: #fb923c; }

  .prose-premium ul, .prose-premium ol {
    margin: 2rem 0;
    padding-left: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .prose-premium ul { list-style-type: disc; }
  .prose-premium ol { list-style-type: decimal; }
  
  .prose-premium li::marker { color: #f97316; font-weight: bold; }

  .prose-premium blockquote {
    border-left-width: 4px;
    border-color: #ea580c; /* border-orange-600 */
    background-color: rgba(249, 115, 22, 0.05); /* bg-orange-900/10 */
    padding: 1.5rem 2rem;
    border-top-right-radius: 0.75rem;
    border-bottom-right-radius: 0.75rem;
    font-style: italic;
    color: #94a3b8; /* text-gray-400 */
    margin: 2.5rem 0;
  }

  .prose-premium pre {
    background-color: #111827; /* bg-gray-900 */
    border: 1px solid #1f2937; /* border-gray-800 */
    border-radius: 1rem;
    padding: 1.5rem;
    margin: 2.5rem 0;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.625;
  }

  .prose-premium code {
    background-color: #1f2937;
    color: #fdba74; /* text-orange-300 */
    padding: 0.125rem 0.375rem;
    border-radius: 0.125rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 0.9em;
  }

  .prose-premium pre code {
    background-color: transparent;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  .prose-premium img {
    border-radius: 1rem;
    border: 1px solid #1f2937;
    margin: 3rem auto;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    display: block;
  }
</style>
