---
import { Filter } from "lucide-astro";
import Layout from "../../layouts/Layout.astro";
import {
  fetchCategories,
  fetchLimitedPosts,
} from "../../services/blog/BlogService";
import Hero from "../../components/blog/Hero.astro";
import BlogSidebar from "../../components/blog/BlogSidebar.astro";
import PostCard from "../../components/blog/PostCard.astro";

// Fetch inicial de datos: Traemos MUCHOS posts para filtrar en el cliente (estático)
const [categories, initialData] = await Promise.all([
  fetchCategories(),
  // Pedimos hasta 100 posts para tener un buen pool inicial sin paginación de servidor
  fetchLimitedPosts(500),
]);

const allPosts = initialData.posts;
// const totalPosts = initialData.totalItem; // Total real en la DB, aunque aquí tengamos 100
---

<Layout>
  <!-- Hero Section (se mantiene igual, usa datos iniciales para mostrar destacados si quisiera) -->
  <Hero
    initialData={{ posts: allPosts.slice(0, 5), totalPages: 1 }}
    categories={categories}
  />

  <!-- Contenido Dinámico -->
  <section class="bg-gray-900 py-12 px-4 shadow-2xl">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <!-- Main Content Area -->
        <div class="lg:col-span-8 lg:border-r lg:border-gray-800 lg:pr-12">

      <!-- Contador de resultados -->
      <div id="results-info" class="flex items-center justify-between mb-8">
        <p class="text-gray-400">
          Mostrando <span id="posts-count" class="text-white font-semibold"
            >{Math.min(12, allPosts.length)}</span
          > posts
          <span id="category-info"></span>
        </p>
        <p class="text-gray-400 text-sm">
          Página <span id="current-page" class="text-white font-semibold"
            >1</span
          > de
          <span id="total-pages" class="text-white font-semibold">1</span>
        </p>
      </div>

      <!-- Posts Container (Renderizamos TODOS los posts, el JS gestionará visibilidad) -->
      <div
        id="posts-container"
        class="grid grid-cols-1 gap-10 min-h-[400px]"
      >
        {
          allPosts.map((post) => (
            <PostCard post={post} allCategories={categories} />
          ))
        }
      </div>

      <!-- Empty State -->
      <div
        id="empty-state"
        class="hidden text-center py-16 bg-gray-800/30 rounded-2xl border border-gray-700/50"
      >
        <div class="max-w-md mx-auto">
          <div
            class="w-16 h-16 bg-gray-700 rounded-full flex items-center justify-center mx-auto mb-4"
          >
            <svg
              class="w-8 h-8 text-gray-500"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-white mb-2">
            No se encontraron posts
          </h3>
          <p id="empty-message" class="text-gray-400 mb-6">
            No hay posts disponibles en esta categoría.
          </p>
          <button
            id="view-all-btn"
            class="inline-flex items-center gap-2 px-6 py-3 bg-orange-500 hover:bg-orange-600 rounded-xl text-white font-medium transition-all duration-300"
          >
            Ver todos los posts
          </button>
        </div>
      </div>

      <!-- Paginación -->
      <div id="pagination" class="flex justify-center items-center gap-1 md:gap-3 mt-16">
        <button
          id="prev-page"
          class="flex items-center justify-center w-10 h-10 md:w-12 md:h-12 rounded-xl border transition-all duration-300 bg-gray-800 border-gray-700 text-gray-600 pointer-events-none"
          aria-label="Página anterior"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 19l-7-7 7-7"></path>
          </svg>
        </button>

        <div id="page-numbers" class="flex items-center gap-1 md:gap-2">
          <!-- Los números de página se generarán aquí -->
        </div>

        <button
          id="next-page"
          class="flex items-center justify-center w-10 h-10 md:w-12 md:h-12 rounded-xl border transition-all duration-300 bg-gray-800 border-gray-600 text-white hover:bg-orange-500 hover:border-orange-500 hover:scale-105"
          aria-label="Página siguiente"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </button>
      </div>
        </div>

        <!-- Sidebar Area -->
        <div class="lg:col-span-4">
          <BlogSidebar />
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Lógica "Client-Side Only" para filtrado y paginación

  // Configuración
  const PER_PAGE = 6; // Cantidad de posts por página

  // Elementos
  const elements = {
    postsContainer: document.getElementById("posts-container"),
    postItems: document.querySelectorAll(".post-item"),
    emptyState: document.getElementById("empty-state"),
    emptyMessage: document.getElementById("empty-message"),
    viewAllBtn: document.getElementById("view-all-btn"),

    postsCount: document.getElementById("posts-count"),
    categoryInfo: document.getElementById("category-info"),

    currentPageEsp: document.getElementById("current-page"),
    totalPagesEsp: document.getElementById("total-pages"),
    pagination: document.getElementById("pagination"),
    pageNumbers: document.getElementById("page-numbers"),
    prevBtn: document.getElementById("prev-page"),
    nextBtn: document.getElementById("next-page"),

    filterIndicator: document.getElementById("filter-indicator"),
    filterName: document.getElementById("filter-name"),
    clearFilter: document.getElementById("clear-filter"),

    categoryBtns: document.querySelectorAll(".category-btn"),
  };

  // Estado local
  let state = {
    currentCategory: "all",
    searchQuery: "",
    currentPage: 1,
    filteredPosts: [] as HTMLElement[], // Array de elementos del DOM que coinciden con filtro
    totalPages: 1,
  };

  function init() {
    // Leer parámetros de la URL al cargar
    const params = new URLSearchParams(window.location.search);
    const catParam = params.get('category');
    const searchParam = params.get('search');

    if (catParam) state.currentCategory = catParam;
    if (searchParam) state.searchQuery = searchParam;

    applyFilters();
  }

  function applyFilters() {
    const allItems = Array.from(elements.postItems) as HTMLElement[];
    state.currentPage = 1;

    state.filteredPosts = allItems.filter((item) => {
      // Filtro por Categoría
      let matchesCategory = true;
      if (state.currentCategory !== 'all') {
        const cats = item.dataset.categories?.split(",") || [];
        matchesCategory = cats.includes(state.currentCategory);
      }

      // Filtro por Búsqueda
      let matchesSearch = true;
      if (state.searchQuery) {
        const title = item.querySelector('h3')?.textContent?.toLowerCase() || "";
        const q = state.searchQuery.toLowerCase();
        matchesSearch = title.includes(q);
      }

      return matchesCategory && matchesSearch;
    });

    calculateTotalPages();
    updateView();
    updateFilterUI();
  }

  function calculateTotalPages() {
    state.totalPages = Math.ceil(state.filteredPosts.length / PER_PAGE);
    if (state.totalPages < 1) state.totalPages = 1;
  }

  function filterPosts(category: string) {
    state.currentCategory = category;
    applyFilters();
  }

  function changePage(newPage: number) {
    if (newPage < 1 || newPage > state.totalPages) return;
    state.currentPage = newPage;
    updateView();

    // Scroll suave al top de sección
    document.querySelector("section.bg-gray-900")?.scrollIntoView({
      behavior: "smooth",
      block: "start",
    });
  }

  function updateView() {
    // 1. Ocultar todos primero
    elements.postItems.forEach((item) => item.classList.add("hidden"));

    // 2. Determinar cuáles mostrar según paginación
    const start = (state.currentPage - 1) * PER_PAGE;
    const end = start + PER_PAGE;
    const visibleItems = state.filteredPosts.slice(start, end);

    // 3. Mostrarlos
    visibleItems.forEach((item) => item.classList.remove("hidden"));

    // 4. Actualizar contadores y textos
    if (elements.postsCount)
      elements.postsCount.textContent = state.filteredPosts.length.toString();
    if (elements.currentPageEsp)
      elements.currentPageEsp.textContent = state.currentPage.toString();
    if (elements.totalPagesEsp)
      elements.totalPagesEsp.textContent = state.totalPages.toString();

    // 5. Empty State
    if (state.filteredPosts.length === 0) {
      elements.postsContainer?.classList.add("hidden");
      elements.emptyState?.classList.remove("hidden");
      elements.pagination?.classList.add("hidden");
    } else {
      elements.postsContainer?.classList.remove("hidden");
      elements.emptyState?.classList.add("hidden");
      if (state.totalPages > 1) {
        elements.pagination?.classList.remove("hidden");
      } else {
        elements.pagination?.classList.add("hidden");
      }
    }

    // 6. Actualizar Botones de Paginación
    renderPaginationButtons();
  }

  function updateFilterUI() {
    const category = state.currentCategory;
    const query = state.searchQuery;

    // Actualizar estilo botones categorías
    elements.categoryBtns.forEach((btn) => {
      const btnEl = btn as HTMLElement;
      const gradient = btnEl.querySelector("div:first-child"); // Primer div es el gradiente

      if (btnEl.dataset.category === category) {
        // Active state with Glow & Ring
        btnEl.classList.remove(
          "text-gray-400",
          "bg-gray-800/40",
          "border-gray-700/50",
        );
        btnEl.classList.add(
          "text-white",
          "border-transparent",
          "active-category",
          "shadow-[0_0_20px_rgba(249,115,22,0.4)]", // Custom glow
          "ring-1",
          "ring-orange-400/50",
          "scale-105", // Slight scale up
        );
        if (gradient) {
          gradient.classList.remove("opacity-0");
          gradient.classList.add("opacity-100");
        }
      } else {
        // Inactive state
        btnEl.classList.add(
          "text-gray-400",
          "bg-gray-800/40",
          "border-gray-700/50",
        );
        btnEl.classList.remove(
          "text-white",
          "border-transparent",
          "active-category",
          "shadow-[0_0_20px_rgba(249,115,22,0.4)]",
          "ring-1",
          "ring-orange-400/50",
          "scale-105",
        );
        if (gradient) {
          gradient.classList.add("opacity-0");
          gradient.classList.remove("opacity-100");
        }
      }
    });

    // Actualizar indicador de filtro (texto "Filtrando por...")
    if (category !== "all" || query) {
      // buscar nombre categoría
      const btn = Array.from(elements.categoryBtns).find(
        (b) => (b as HTMLElement).dataset.category === category,
      );
      const catName = btn
        ? btn.querySelector("span.relative")?.childNodes[0].textContent?.trim()
        : category;

      let displayText = "";
      if (category !== "all") displayText += ` en <span class="text-orange-400 font-semibold">${catName}</span>`;
      if (query) displayText += ` buscando <span class="text-orange-400 font-semibold">"${query}"</span>`;

      if (elements.categoryInfo) elements.categoryInfo.innerHTML = displayText;
      
      if (elements.filterIndicator) {
        elements.filterIndicator.classList.remove("hidden");
        elements.filterIndicator.classList.add("flex");
      }
      
      if (elements.filterName) {
        let label = "";
        if (category !== "all") label += catName;
        if (query) label += (label ? " + " : "") + `"${query}"`;
        elements.filterName.textContent = label;
      }
    } else {
      if (elements.categoryInfo) elements.categoryInfo.innerHTML = "";
      if (elements.filterIndicator) {
        elements.filterIndicator.classList.add("hidden");
        elements.filterIndicator.classList.remove("flex");
      }
    }
  }

  function renderPaginationButtons() {
    // Logic para prev/next habilitado/deshabilitado
    const prev = elements.prevBtn as HTMLButtonElement;
    const next = elements.nextBtn as HTMLButtonElement;

    if (state.currentPage === 1) {
      prev.classList.add(
        "pointer-events-none",
        "text-gray-600",
        "border-gray-700",
      );
      prev.classList.remove(
        "text-white",
        "border-gray-600",
        "hover:bg-orange-500",
        "hover:border-orange-500",
        "hover:scale-105",
      );
    } else {
      prev.classList.remove(
        "pointer-events-none",
        "text-gray-600",
        "border-gray-700",
      );
      prev.classList.add(
        "text-white",
        "border-gray-600",
        "hover:bg-orange-500",
        "hover:border-orange-500",
        "hover:scale-105",
      );
    }

    if (state.currentPage >= state.totalPages) {
      next.classList.add(
        "pointer-events-none",
        "text-gray-600",
        "border-gray-700",
      );
      next.classList.remove(
        "text-white",
        "border-gray-600",
        "hover:bg-orange-500",
        "hover:border-orange-500",
        "hover:scale-105",
      );
    } else {
      next.classList.remove(
        "pointer-events-none",
        "text-gray-600",
        "border-gray-700",
      );
      next.classList.add(
        "text-white",
        "border-gray-600",
        "hover:bg-orange-500",
        "hover:border-orange-500",
        "hover:scale-105",
      );
    }

    // Renderizar números (Lógica responsiva)
    const container = elements.pageNumbers;
    if (!container) return;
    container.innerHTML = "";

    const isMobile = window.innerWidth < 640;
    const pages = [];
    const maxVisible = isMobile ? 3 : 7; // Mostrar menos números en móvil

    if (state.totalPages <= maxVisible) {
      for (let i = 1; i <= state.totalPages; i++) pages.push(i);
    } else {
      pages.push(1);
      
      const sidePages = isMobile ? 0 : 1; 
      let s = Math.max(2, state.currentPage - sidePages);
      let e = Math.min(state.totalPages - 1, state.currentPage + sidePages);

      if (s > 2) pages.push("...");
      for (let i = s; i <= e; i++) pages.push(i);
      if (e < state.totalPages - 1) pages.push("...");
      
      pages.push(state.totalPages);
    }

    pages.forEach((p) => {
      if (p === "...") {
        const span = document.createElement("span");
        span.className =
          "w-8 h-8 md:w-12 md:h-12 flex items-center justify-center text-gray-500";
        span.textContent = "...";
        container.appendChild(span);
      } else {
        const btn = document.createElement("button");
        const isCurr = p === state.currentPage;
        btn.className = `w-10 h-10 md:w-12 md:h-12 rounded-xl border flex items-center justify-center transition-all duration-300 text-xs md:text-sm ${
          isCurr
            ? "bg-orange-500 border-orange-500 text-white shadow-lg shadow-orange-500/25 scale-105 font-bold"
            : "bg-gray-800 border-gray-600 text-white hover:bg-gray-700 hover:scale-105"
        }`;
        btn.textContent = p.toString();
        btn.onclick = () => changePage(p as number);
        container.appendChild(btn);
      }
    });
  }

  // Nota: Los categoryBtns ya no existen en el index principal, sino en el sidebar.
  // Pero el sidebar genera navegación (/blog?category=...). 
  // Así que dependemos del init() que lee de la URL.
  
  // elements.categoryBtns ya no es necesario aquí para clics directos, 
  // pero mantendremos la lógica de applyFilters() para cuando cambie la URL.

  elements.clearFilter?.addEventListener("click", () => {
    state.currentCategory = "all";
    state.searchQuery = "";
    // Limpiar URL sin recargar
    window.history.replaceState({}, '', '/blog');
    applyFilters();
  });
  elements.viewAllBtn?.addEventListener("click", () => {
    state.currentCategory = "all";
    state.searchQuery = "";
    window.history.replaceState({}, '', '/blog');
    applyFilters();
  });
  elements.prevBtn?.addEventListener("click", () =>
    changePage(state.currentPage - 1),
  );
  elements.nextBtn?.addEventListener("click", () =>
    changePage(state.currentPage + 1),
  );

  // Init
  init();
</script>
